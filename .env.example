# ============================================================
# Mais que Mimo — Environment Variables Template
# ============================================================
# Copie este arquivo para .env.local e configure os valores

# ============================================================
# Backend (Spring Boot)
# ============================================================

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/maisquemimo_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT
JWT_SECRET=sua-chave-super-secreta-muito-longa-e-segura-aqui
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Spring Boot
SPRING_PROFILES_ACTIVE=dev
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SERVER_PORT=8080

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_MAISQUEMIMO=DEBUG

# ============================================================
# Frontend (Next.js)
# ============================================================

# API
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_NAME=Mais que Mimo

# Analytics (futuro)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# ============================================================
# Integrações Externas (futuro)
# ============================================================

# Correios
CORREIOS_API_KEY=sua-chave-correios
CORREIOS_API_URL=https://api.correios.com.br

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=seu-token-mercado-pago
MERCADO_PAGO_PUBLIC_KEY=sua-chave-publica-mp

# Email
SMTP_HOST=smtp.seu-provider.com
SMTP_PORT=587
SMTP_USERNAME=seu-email@example.com
SMTP_PASSWORD=sua-senha-email
SMTP_FROM=noreply@maisquemimo.com.br

# ============================================================
# Docker
# ============================================================

POSTGRES_DB=maisquemimo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
