# ========================================
# MAIS QUE MIMO E-COMMERCE
# Arquivo de Exemplo de Variáveis de Ambiente
# ========================================
#
# INSTRUÇÕES:
# 1. Em DESENVOLVIMENTO LOCAL:
#    - application.yml tem fallbacks automáticos
#    - Não precisa criar .env (os defaults abaixo funcionam)
#    - docker-compose.yml já define tudo necessário
#
# 2. Em PRODUÇÃO (Railway + Neon):
#    - Configure TODAS as variáveis no dashboard Railway
#    - JWT_SECRET OBRIGATÓRIO (gere: openssl rand -base64 32)
#    - SPRING_DATASOURCE_URL do Neon (com ?sslmode=require)
#    - SPRING_PROFILES_ACTIVE=prod OBRIGATÓRIO
#

# ========================================
# BACKEND - SPRING PROFILES
# ========================================

# Profiles: dev (desenvolvimento com DEBUG), prod (produção com INFO)
# OBRIGATÓRIO em Railway: prod
SPRING_PROFILES_ACTIVE=dev

# ========================================
# BACKEND - DATABASE CONFIGURATION
# ========================================

# Em PRODUÇÃO: Use Neon PostgreSQL
# Connection String (precedência sobre username/password)
# Formato: postgresql://username:password@host:port/database?sslmode=require
# Exemplo Railway + Neon:
# postgresql://postgres:abc123@ep-cool-lake-123456.us-east-1.aws.neon.tech/maisquemimo_db?sslmode=require&connectTimeout=10&socketTimeout=30
SPRING_DATASOURCE_URL=postgresql://postgres:postgres@localhost:5432/maisquemimo_db

# Alternativa: Usar username e password separados (não recomendado em produção)
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ========================================
# BACKEND - SERVER CONFIGURATION
# ========================================

# Porta (Railway injeta PORT automaticamente, mas respeita SERVER_PORT)
# Default: 8080
SERVER_PORT=8080

# ========================================
# BACKEND - JWT SECURITY CONFIGURATION
# ========================================

# 🔐 CRÍTICO EM PRODUÇÃO: Gerar novo secret!
# Local: openssl rand -base64 32
# Mínimo 32 caracteres, use caracteres especiais
# NUNCA use valor padrão em produção
JWT_SECRET=dev-secret-change-in-production-openssl-rand-base64-32

# Token expiration em millisegundos (86400000 = 24 horas)
JWT_EXPIRATION=86400000

# Refresh token expiration em millisegundos (604800000 = 7 dias)
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# BACKEND - JPA/HIBERNATE CONFIGURATION
# ========================================

# DDL strategy: validate (prod), create-drop (teste), update (dev)
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ========================================
# BACKEND - LOGGING CONFIGURATION
# ========================================

# Nível global (DEBUG=verbose, INFO=normal, WARN=alertas, ERROR=erros apenas)
# Recomendado: INFO em prod, DEBUG em dev
LOGGING_LEVEL_ROOT=INFO

# Nível da aplicação
# Recomendado: INFO em prod, DEBUG em dev
LOGGING_LEVEL_COM_MAISQUEMIMO=INFO

# Nível Spring Security
# Recomendado: WARN em prod, DEBUG em dev
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=WARN

# Nível Spring Framework
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO

# Nível Hibernate
LOGGING_LEVEL_ORG_HIBERNATE=INFO

# Nível Flyway
LOGGING_LEVEL_ORG_FLYWAYDB=INFO

# ========================================
# BACKEND - DATASOURCE CONNECTION POOL
# ========================================

# HikariCP pool configuration (ajustado por profile)
# Recomendado: 10-20 dev, 20-50 prod
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000

# ========================================
# FRONTEND (Next.js 15)
# ========================================

# API URL (sem /api no final, adicionado em api.ts)
# Dev: http://localhost:8080
# Prod: https://api.maisquemimo.com ou https://api-prod-xxx.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8080

# App name
NEXT_PUBLIC_APP_NAME=Mais que Mimo

# Google Analytics (futuro)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# ============================================================
# Integrações Externas (futuro)
# ============================================================

# 📦 Correios (Shipping)
CORREIOS_API_KEY=
CORREIOS_API_URL=https://api.correios.com.br

# 💳 Mercado Pago (Payments)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_PUBLIC_KEY=

# 📧 Email SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@maisquemimo.com.br

# ============================================================
# CHECKLISTS
# ============================================================

# ✅ DESENVOLVIMENTO LOCAL (docker-compose)
# Todos os valores padrão em application-dev.yml
# Apenas execute: docker-compose up
# Nada precisa ser configurado

# ✅ PRODUÇÃO (Railway + Neon)
# Verificar ANTES de fazer deploy:
# [ ] SPRING_PROFILES_ACTIVE=prod
# [ ] JWT_SECRET gerado (openssl rand -base64 32)
# [ ] SPRING_DATASOURCE_URL do Neon (com ?sslmode=require)
# [ ] LOGGING_LEVEL_*=INFO (não DEBUG)
# [ ] SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE≥20
# [ ] Testado localmente com application-prod.yml
# [ ] Variáveis configuradas no Railway Dashboard
# [ ] Git commit com todas as mudanças
# [ ] git push origin main (Railway autodeploy)

# ============================================================
# SEGURANÇA
# ============================================================

# ⚠️ NUNCA COMMITAR VALORES REAIS
# ✅ Use este arquivo como template
# ✅ Valores reais apenas em Railway Dashboard (seguro)
# ✅ JWT_SECRET deve ser diferente por ambiente
# ✅ Database password protegida em produção


# ========================================
# RAILWAY DEPLOYMENT INSTRUCTIONS
# ========================================
#
# 1. Provisionar PostgreSQL no Railway:
#    $ railway link
#    $ railway add --service postgresql
#
# 2. Conectar com Neon (opcional):
#    $ Neon Console > Connection String
#    $ Copie: postgresql://user:password@host/dbname
#
# 3. Configurar Variáveis no Railway:
#    $ railway service add backend
#    $ railway variables:set SPRING_DATASOURCE_URL=postgresql://...
#    $ railway variables:set JWT_SECRET=$(openssl rand -base64 32)
#    $ railway variables:set JWT_EXPIRATION=86400000
#    $ railway variables:set JWT_REFRESH_EXPIRATION=604800000
#    $ railway variables:set SPRING_PROFILES_ACTIVE=prod
#
# 4. Deploy:
#    $ railway up
#    $ railway open
#
# 5. Monitorar:
#    $ railway logs
#
# ========================================
# DESENVOLVIMENTO LOCAL
# ========================================
#
# Backend rodando localmente:
# $ cd backend
# $ mvn spring-boot:run
#
# Ou com variáveis de ambiente:
# $ export JWT_SECRET=$(openssl rand -base64 32)
# $ mvn spring-boot:run
#
# ========================================
# SEGURANÇA - CHECKLIST PRODUÇÃO
# ========================================
#
# ❌ Nunca fazer:
#    - Commitar .env com valores reais
#    - Reutilizar JWT_SECRET do desenvolvimento
#    - Deixar banco com usuário/senha padrão
#    - Expor connection strings públicas
#
# ✅ Sempre fazer:
#    - Gerar JWT_SECRET segura: openssl rand -base64 32
#    - Usar secrets manager do Railway
#    - Manter senha forte do banco
#    - Revisar variáveis antes de deploy
#
# ========================================

# ============================================================
# Docker
# ============================================================

POSTGRES_DB=maisquemimo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
