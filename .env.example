# ========================================
# MAIS QUE MIMO E-COMMERCE
# Arquivo de Exemplo de Variáveis de Ambiente
# ========================================
#
# INSTRUÇÕES:
# 1. Em DESENVOLVIMENTO LOCAL: Valores com fallback já estão definidos em application.yml
#    Você NÃO precisa criar um arquivo .env (os valores abaixo serão defaults)
#
# 2. Em PRODUÇÃO (Railway + Neon): Configure as variáveis no dashboard do Railway
#    Remova o fallback para forçar configuração obrigatória
#

# ========================================
# BACKEND - DATABASE CONFIGURATION (Neon PostgreSQL)
# ========================================

# Connection String (SPRING_DATASOURCE_URL precedência sobre username/password)
# Formato: postgresql://username:password@host:port/database
# Railway + Neon: Obtenha no dashboard do Neon
SPRING_DATASOURCE_URL=postgresql://postgres:postgres@localhost:5432/maisquemimo_db

# Alternativa: Usar username e password separados
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ========================================
# BACKEND - SERVER CONFIGURATION
# ========================================

# Porta do servidor (Railway injeta PORT automaticamente)
SERVER_PORT=8080

# ========================================
# BACKEND - JWT SECURITY CONFIGURATION
# ========================================

# Chave secreta para assinar JWTs (MUDAR EM PRODUÇÃO!)
# Mínimo 32 caracteres recomendados
# Gere: openssl rand -base64 32
JWT_SECRET=sua-chave-super-secreta-muito-longa-e-segura-aqui

# Expiração do token em millisegundos (24 horas = 86400000)
JWT_EXPIRATION=86400000

# Expiração do refresh token em millisegundos (7 dias = 604800000)
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# BACKEND - SPRING CONFIGURATION
# ========================================

# Profiles: dev (desenvolvimento), prod (produção)
SPRING_PROFILES_ACTIVE=dev

# JPA/Hibernate DDL strategy
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ========================================
# BACKEND - LOGGING CONFIGURATION
# ========================================

# Nível de logging global
LOGGING_LEVEL_ROOT=INFO

# Nível de logging da aplicação
LOGGING_LEVEL_COM_MAISQUEMIMO=DEBUG

# Nível de logging do Spring Security
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG

# ============================================================
# Frontend (Next.js)
# ============================================================

# API
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_APP_NAME=Mais que Mimo

# Analytics (futuro)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# ============================================================
# Integrações Externas (futuro)
# ============================================================

# Correios
CORREIOS_API_KEY=sua-chave-correios
CORREIOS_API_URL=https://api.correios.com.br

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=seu-token-mercado-pago
MERCADO_PAGO_PUBLIC_KEY=sua-chave-publica-mp

# Email
SMTP_HOST=smtp.seu-provider.com
SMTP_PORT=587
SMTP_USERNAME=seu-email@example.com
SMTP_PASSWORD=sua-senha-email
SMTP_FROM=noreply@maisquemimo.com.br

# ========================================
# RAILWAY DEPLOYMENT INSTRUCTIONS
# ========================================
#
# 1. Provisionar PostgreSQL no Railway:
#    $ railway link
#    $ railway add --service postgresql
#
# 2. Conectar com Neon (opcional):
#    $ Neon Console > Connection String
#    $ Copie: postgresql://user:password@host/dbname
#
# 3. Configurar Variáveis no Railway:
#    $ railway service add backend
#    $ railway variables:set SPRING_DATASOURCE_URL=postgresql://...
#    $ railway variables:set JWT_SECRET=$(openssl rand -base64 32)
#    $ railway variables:set JWT_EXPIRATION=86400000
#    $ railway variables:set JWT_REFRESH_EXPIRATION=604800000
#    $ railway variables:set SPRING_PROFILES_ACTIVE=prod
#
# 4. Deploy:
#    $ railway up
#    $ railway open
#
# 5. Monitorar:
#    $ railway logs
#
# ========================================
# DESENVOLVIMENTO LOCAL
# ========================================
#
# Backend rodando localmente:
# $ cd backend
# $ mvn spring-boot:run
#
# Ou com variáveis de ambiente:
# $ export JWT_SECRET=$(openssl rand -base64 32)
# $ mvn spring-boot:run
#
# ========================================
# SEGURANÇA - CHECKLIST PRODUÇÃO
# ========================================
#
# ❌ Nunca fazer:
#    - Commitar .env com valores reais
#    - Reutilizar JWT_SECRET do desenvolvimento
#    - Deixar banco com usuário/senha padrão
#    - Expor connection strings públicas
#
# ✅ Sempre fazer:
#    - Gerar JWT_SECRET segura: openssl rand -base64 32
#    - Usar secrets manager do Railway
#    - Manter senha forte do banco
#    - Revisar variáveis antes de deploy
#
# ========================================

# ============================================================
# Docker
# ============================================================

POSTGRES_DB=maisquemimo_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
